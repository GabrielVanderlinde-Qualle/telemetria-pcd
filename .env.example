# =============================================================================
# ARQUIVO DE CONFIGURAÇÃO - COPIE PARA .env E PREENCHA OS VALORES
# cp .env.example .env
#
# ⚠️  NUNCA commite o arquivo .env no Git (já está no .gitignore)
# =============================================================================

# -------------------------
# URL pública do Grafana
# -------------------------
# Exemplo com IP: http://10.0.0.50:3000
# Exemplo com domínio: https://monitoramento.suaempresa.com.br
GF_SERVER_ROOT_URL=http://SEU_IP_OU_DOMINIO:3000
GF_SERVER_DOMAIN=SEU_IP_OU_DOMINIO

# -------------------------
# Segurança do Grafana
# -------------------------
# Gere uma chave aleatória: openssl rand -base64 32
GF_SECURITY_SECRET_KEY=COLE_AQUI_CHAVE_ALEATORIA_GERADA

# Usuário administrador local (fallback caso Azure AD falhe)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=SENHA_FORTE_AQUI

# -------------------------
# Autenticação Microsoft (Azure AD)
# -------------------------
# Veja docs/AUTENTICACAO.md para como obter esses valores no portal Azure
AZURE_CLIENT_ID=SEU_CLIENT_ID_AQUI
AZURE_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI
AZURE_TENANT_ID=SEU_TENANT_ID_AQUI

# Domínios permitidos (separados por espaço)
# Exemplo: suaempresa.com.br outro.dominio.com
AZURE_ALLOWED_DOMAINS=suaempresa.com.br

# Grupos Azure AD permitidos (deixe vazio para permitir todos do domínio)
AZURE_ALLOWED_GROUPS=

# Habilitar autenticação Azure
GF_AUTH_AZUREAD_ENABLED=true

# Desabilitar formulário de login padrão (recomendado após Azure configurado)
GF_AUTH_DISABLE_LOGIN_FORM=false

# Login automático via Azure (ativa após confirmar que Azure está funcionando)
GF_AUTH_AZUREAD_AUTO_LOGIN=false

# -------------------------
# Zabbix API
# -------------------------
ZABBIX_URL=http://SEU_IP_ZABBIX:8888/api_jsonrpc.php
ZABBIX_TOKEN=SEU_TOKEN_API_ZABBIX
